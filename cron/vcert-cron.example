# =============================================================================
# Example crontab entry for automatic renewal via VCERT
# Install with:  crontab -e   (then paste the line below, adjusting the paths)
#
# VCERT only renews when less than "renewBefore" is left before expiry, so
# running frequently (e.g., every 12h) is safe and recommended.
# =============================================================================

# Loads the token from a protected environment file (chmod 600).
# At 06:00 and 18:00 every day.
0 6,18 * * * VCERT_TOKEN="$(cat /etc/vcert/token)" /usr/local/bin/vcert run -f /etc/vcert/playbook.yaml >> /var/log/vcert.log 2>&1
